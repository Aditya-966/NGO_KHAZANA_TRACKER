# PostgreSQL connection string
DATABASE_URL="postgresql://ngo_user:ngo_password@localhost:5432/ngo_ledger?schema=public"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="8h"

# Frontend origin allowed to call this API (CORS)
FRONTEND_ORIGIN="http://localhost:5173"

# Central admin seed credentials (used once by `npm run seed`)
CENTRAL_LOGIN_ID="central"
CENTRAL_SEED_PASSWORD="ChangeMe123!"
